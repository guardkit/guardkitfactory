*.log
*debug*.log
*DEBUG*.md
debug-*.md
*-debug.md

# Backup directories
*.backup/
*.backup.*
.*.backup.*

# Session and state files (moved to .claude/state/)
.template-create-state.json
.template-init-session.json
/*-session.json
/*-state.json
/*.session.json
/*.state.json

# Process-acquired runtime locks (machine-local; never check in)
.claude/*.lock
.claude/state/*.lock
/.guardkit-git.lock

# Archived documents (keep structure but ignore temp/session files in root)
/root-files-inventory.txt
/categorized-inventory.txt

# Temporary test files in root
/test_*.py
/test_*.txt
/validate_*.py

# Temporary Python scripts in root
/add_frontmatter_to_agents.py
/complexity_evaluation_*.py
/demo_*.py
/debug-*.py

# MkDocs build artifacts
site/

# OS generated files
*.orig*.py,cover

# Per-machine Claude Code overrides
.claude/settings.local.json