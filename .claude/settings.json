{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/capture_slash_command.py"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
